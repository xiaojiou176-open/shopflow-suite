# Shopflow environment template
#
# Copy only the variables you need into a local `.env` or shell session.
# Do not commit real credentials.

# Optional cache overrides
# SHOPFLOW_CACHE_DIR=$HOME/.cache/shopflow
# SHOPFLOW_CACHE_TTL_DAYS=3
# SHOPFLOW_CACHE_MAX_BYTES=2147483648

# Optional live-browser overrides
# SHOPFLOW_LIVE=1
# SHOPFLOW_LIVE_USER_DATA_DIR=$HOME/.cache/shopflow/browser/chrome-user-data
# SHOPFLOW_LIVE_PROFILE_DIRECTORY=Profile 1
# SHOPFLOW_LIVE_PROFILE_NAME=shopflow
# SHOPFLOW_LIVE_ATTACH_MODE=auto
# SHOPFLOW_LIVE_CDP_URL=http://127.0.0.1:9335
# SHOPFLOW_LIVE_TARGETS=safeway-home,safeway-cart,safeway-manage,fred-meyer-coupons,qfc-search,temu-search
# SHOPFLOW_LIVE_CHROME_EXECUTABLE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Optional provider-runtime seam example
# SHOPFLOW_SWITCHYARD_BASE_URL=http://127.0.0.1:4317

# Optional release-review manifest helpers
# SHOPFLOW_APP_ID=ext-temu
# SHOPFLOW_PACKAGE_NAME=@shopflow/ext-temu
# SHOPFLOW_REVIEW_CHANNEL=store-review
# SHOPFLOW_SURFACE=storefront-shell
# SHOPFLOW_APP_DIR=apps/ext-temu
